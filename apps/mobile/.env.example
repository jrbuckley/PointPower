# Copy to .env — same values as apps/api/.env (with EXPO_PUBLIC_ prefix for Expo)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback (older JWT "anon" key):
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# iOS Simulator: http://localhost:3000
# Physical device: use your Mac's LAN IP, e.g. http://192.168.1.169:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

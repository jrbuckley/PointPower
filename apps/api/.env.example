PORT=3000
HOST=0.0.0.0

# Copy to apps/api/.env (loaded automatically on dev/start).

# Same project URL as EXPO_PUBLIC_SUPABASE_URL in apps/mobile/.env
SUPABASE_URL=
# Publishable key from Supabase → Project Settings → API Keys
SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback (older JWT "anon" key):
# SUPABASE_ANON_KEY=
